# ============================================================
# ContractSense — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ─── Core API (Node.js) ─────────────────────────────────────
DATABASE_URL=postgresql://cs_user:cs_password@localhost:5432/contractsense
JWT_SECRET=change_me_jwt_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_32_chars
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=contracts
STRIPE_SECRET_KEY=sk_test_replace_with_real_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_real_secret
CORS_ORIGINS=http://localhost,http://localhost:3000
PORT=4000

# ─── AI Backend (Python) ────────────────────────────────────
OPENAI_API_KEY=sk-replace_with_real_openai_key
MONGODB_URI=mongodb://cs_user:cs_password@localhost:27017/contractsense
CORE_API_CALLBACK_URL=http://core-api:4000/api/core/contracts

# ─── Frontend (Next.js) ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api/core
NEXTAUTH_SECRET=change_me_nextauth_secret_at_least_32_chars
NEXTAUTH_URL=http://localhost

# ─── MinIO (Object Storage) ─────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_DB=contractsense
POSTGRES_USER=cs_user
POSTGRES_PASSWORD=cs_password

# ─── MongoDB ────────────────────────────────────────────────
MONGO_INITDB_ROOT_USERNAME=cs_user
MONGO_INITDB_ROOT_PASSWORD=cs_password
MONGO_INITDB_DATABASE=contractsense
